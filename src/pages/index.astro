---
import { Font } from 'astro:assets';
import PhoneMockup from '@/components/phone-mockup.astro';
import '@/styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<meta
			name="description"
			content="Android can be safer without becoming smaller. Help build the open path."
		/>
		<meta
			property="og:title"
			content="helpsaveandroid.org"
		/>
		<meta
			property="og:description"
			content="Android can be safer without becoming smaller. Help build the open path."
		/>
		<Font cssVariable="--font-serif" />
		<title>helpsaveandroid.org</title>
	</head>
	<body>
		<a
			href="#top"
			class="side-wordmark"
			aria-label="helpsaveandroid.org home"
		>
			helpsaveandroid<span class="text-[var(--accent)]">.</span>org
		</a>

		<main
			id="top"
			class="relative overflow-x-clip"
		>
			<section
				class="relative mx-auto grid max-w-screen-xl px-5 sm:px-8 lg:grid-cols-[minmax(0,1fr)_minmax(19rem,27rem)] lg:gap-16 lg:px-12 xl:gap-24"
			>
				<div class="relative z-10">
					<div class="sticky top-4 z-20 mx-auto mb-12 flex justify-center lg:hidden">
						<PhoneMockup size="compact" />
					</div>

					<section class="snap-panel flex min-h-screen items-center pb-20 pt-14 lg:pb-24 lg:pt-24">
						<div class="max-w-3xl">
							<p class="type-body italic text-[var(--muted)]">since the beginning of last year,</p>
							<div
								class="type-heading mt-5 max-w-full whitespace-nowrap text-[var(--ink)] tabular-nums"
								data-loss-counter
							>
								$0
							</div>
							<p class="type-body pl-69 mt-6 max-w-2xl italic text-[var(--muted)]">
								has been ruined and lost to scams.
							</p>

							<div class="type-body mt-11 max-w-2xl space-y-5 text-[var(--muted)]">
								<p>
									google is trying to fix this, but they're doing so by tightening their control of android.
								</p>
								<p class="text-[var(--ink)]">what might a better approach, and a better android look like?</p>
							</div>
						</div>
					</section>

					<section
						id="solution"
						class="snap-panel flex min-h-screen items-center py-24"
						data-people-trigger
					>
						<div class="max-w-3xl">
							<p class="type-subheading max-w-2xl text-[var(--ink)]">
								the solution has to work for everyone.
							</p>
							<p class="type-body mt-8 text-[var(--muted)]">it has to be:</p>
							<ol class="type-body mt-4 ml-6 grid text-[var(--ink)]">
								<li class="flex items-baseline gap-4 py-1">
									<span class="text-[var(--accent-strong)]">1.</span>
									<span>safe for grandma,</span>
								</li>
								<li class="flex items-baseline gap-4 py-1">
									<span class="text-[var(--accent-strong)]">2.</span>
									<span>easy for geeks, and</span>
								</li>
								<li class="flex items-baseline gap-4 py-1">
									<span class="text-[var(--accent-strong)]">3.</span>
									<span>anonymous for developers.</span>
								</li>
							</ol>
						</div>
					</section>
				</div>

				<aside class="pointer-events-none sticky top-0 hidden h-screen items-center justify-center lg:flex">
					<PhoneMockup />
				</aside>
			</section>

			<section
				class="snap-panel border-t border-[var(--line)] bg-[var(--paper-raised)] px-5 py-28 sm:px-8 lg:px-12"
			>
				<div class="mx-auto max-w-screen-md">
					<p class="type-body text-[var(--muted)]">
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse android, velit at interdum
						pretium, sem justo tincidunt erat, vitae cursus enim nunc in lectus. Integer convallis posuere
						odio, non pretium augue volutpat vel.
					</p>

					<h2 class="type-heading mt-14 text-[var(--ink)]">
						a safer android does not have to become a smaller android.
					</h2>

					<p class="type-body mt-8 text-[var(--muted)]">
						Praesent vitae leo eu erat dignissim viverra. Etiam non risus eu velit malesuada venenatis.
						Curabitur ut libero non sem faucibus congue at sed arcu.
					</p>

					<div class="my-16 grid gap-4 lg:-ml-36 lg:w-[calc(100%+18rem)] lg:grid-cols-3">
						<article
							class="rounded-lg border border-[var(--line)] bg-[var(--paper)] p-6 shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-subheading text-[var(--ink)]">local first</p>
							<p class="type-body mt-4 text-[var(--muted)]">
								Lorem ipsum dolor sit amet, consectetur adipiscing elit. Risk signals can live close to the
								user.
							</p>
						</article>
						<article
							class="rounded-lg border border-[var(--line)] bg-[var(--paper)] p-6 shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-subheading text-[var(--ink)]">open review</p>
							<p class="type-body mt-4 text-[var(--muted)]">
								Nulla facilisi. Communities can audit claims without handing one company the final word.
							</p>
						</article>
						<article
							class="rounded-lg border border-[var(--line)] bg-[var(--paper)] p-6 shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-subheading text-[var(--ink)]">private by default</p>
							<p class="type-body mt-4 text-[var(--muted)]">
								Aliquam erat volutpat. Developers should not need public identity to publish useful software.
							</p>
						</article>
					</div>

					<p class="type-body text-[var(--muted)]">
						Donec suscipit, magna in ullamcorper placerat, magna mi blandit risus, non tempor quam massa id
						augue. Vivamus at ex id est convallis hendrerit. Phasellus in risus vel lacus finibus aliquet.
					</p>
				</div>
			</section>
		</main>

		<script is:inline>
			const scamStart = new Date('2025-01-01T00:00:00.000Z').getTime();
			const annualLossUsd = 400_000_000_000;
			const msPerYear = 365 * 24 * 60 * 60 * 1000;
			const formatter = new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 0,
			});

			const counters = document.querySelectorAll('[data-loss-counter]');
			const loadAt = performance.now();

			const lossAt = (time) => Math.max(0, ((time - scamStart) / msPerYear) * annualLossUsd);
			const easeOut = (value) => 1 - Math.pow(1 - value, 3);

			const renderCounter = (now) => {
				const progress = Math.min(1, (now - loadAt) / 1800);
				const displayValue = lossAt(Date.now()) * easeOut(progress);
				counters.forEach((counter) => {
					counter.textContent = formatter.format(displayValue);
				});
				requestAnimationFrame(renderCounter);
			};

			if (counters.length) {
				requestAnimationFrame(renderCounter);
			}

			const phones = document.querySelectorAll('[data-phone]');
			const peopleTrigger = document.querySelector('[data-people-trigger]');
			let ticking = false;
			let phoneReady = false;

			const updatePhoneMode = () => {
				if (!peopleTrigger) return;
				const shouldShowPeople = peopleTrigger.getBoundingClientRect().top < window.innerHeight * 0.58;
				phones.forEach((phone) => {
					phone.setAttribute('data-mode', shouldShowPeople ? 'people' : 'chat');
				});
				if (!phoneReady) {
					phoneReady = true;
					requestAnimationFrame(() => {
						phones.forEach((phone) => phone.classList.add('is-ready'));
					});
				}
				ticking = false;
			};

			const requestPhoneUpdate = () => {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(updatePhoneMode);
			};

			requestPhoneUpdate();
			window.addEventListener('scroll', requestPhoneUpdate, { passive: true });
			window.addEventListener('resize', requestPhoneUpdate);
		</script>
	</body>
</html>
