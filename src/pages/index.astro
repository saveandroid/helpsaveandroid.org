		<script is:inline>
			const scamStart = new Date('2025-01-01T00:00:00.000Z').getTime();
			const annualLossUsd = 400_000_000_000;
			const msPerYear = 365 * 24 * 60 * 60 * 1000;
			const formatter = new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 0,
			});

			const counters = document.querySelectorAll('[data-loss-counter]');
			const regularScrollStart = document.querySelector('[data-regular-scroll-start]');
			const loadAt = performance.now();

			const lossAt = (time) => Math.max(0, ((time - scamStart) / msPerYear) * annualLossUsd);
			const easeOut = (value) => 1 - Math.pow(1 - value, 3);

			const renderCounter = (now) => {
				const progress = Math.min(1, (now - loadAt) / 1800);
				const displayValue = lossAt(Date.now()) * easeOut(progress);
				counters.forEach((counter) => {
					counter.textContent = formatter.format(displayValue);
				});
				requestAnimationFrame(renderCounter);
			};

			if (counters.length) {
				requestAnimationFrame(renderCounter);
			}

			const daysUntilSeptember = document.querySelectorAll('[data-days-until-september]');
			if (daysUntilSeptember.length) {
				const targetDate = new Date('2026-09-30T00:00:00');
				const startOfToday = new Date();
				startOfToday.setHours(0, 0, 0, 0);
				const msPerDay = 24 * 60 * 60 * 1000;
				const daysRemaining = Math.max(
					0,
					Math.ceil((targetDate.getTime() - startOfToday.getTime()) / msPerDay),
				).toLocaleString('en-US');
				daysUntilSeptember.forEach((counter) => {
					counter.textContent = daysRemaining;
				});
			}

			const phones = document.querySelectorAll('[data-phone]');
			const peopleTrigger = document.querySelector('[data-people-trigger]');
			let ticking = false;
			let phoneReady = false;

			phones.forEach((phone) => {
				const apkTrigger = phone.querySelector('[data-apk-trigger]');
				const apkDialog = phone.querySelector('[data-apk-dialog]');
				const apkClose = phone.querySelector('[data-apk-close]');

				if (!apkTrigger || !apkDialog || !apkClose) return;

				const setScanOpen = (isOpen) => {
					phone.setAttribute('data-scan-open', isOpen ? 'true' : 'false');
					apkTrigger.setAttribute('aria-expanded', String(isOpen));
					apkDialog.setAttribute('aria-hidden', String(!isOpen));
				};

				apkTrigger.addEventListener('click', () => setScanOpen(true));
				apkClose.addEventListener('click', () => setScanOpen(false));
				apkDialog.addEventListener('click', (event) => {
					if (event.target === apkDialog) {
						setScanOpen(false);
					}
				});
			});

			document.addEventListener('keydown', (event) => {
				if (event.key !== 'Escape') return;
				phones.forEach((phone) => {
					phone.setAttribute('data-scan-open', 'false');
					phone.querySelector('[data-apk-trigger]')?.setAttribute('aria-expanded', 'false');
					phone.querySelector('[data-apk-dialog]')?.setAttribute('aria-hidden', 'true');
				});
			});

			const updatePhoneMode = () => {
				if (!peopleTrigger) return;
				const shouldShowPeople = peopleTrigger.getBoundingClientRect().top < window.innerHeight * 0.58;
				phones.forEach((phone) => {
					phone.setAttribute('data-mode', shouldShowPeople ? 'people' : 'chat');
				});
				if (!phoneReady) {
					phoneReady = true;
					requestAnimationFrame(() => {
						phones.forEach((phone) => phone.classList.add('is-ready'));
					});
				}
				ticking = false;
			};

			const updateIntroSnap = () => {
				if (!regularScrollStart) return;
				const isInPhoneIntro = regularScrollStart.getBoundingClientRect().top > window.innerHeight * 0.7;
				document.documentElement.classList.toggle('intro-snap-active', isInPhoneIntro);
			};

			const requestPhoneUpdate = () => {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(() => {
					updatePhoneMode();
					updateIntroSnap();
				});
			};

			const newsPreviewCards = document.querySelectorAll('[data-news-preview-card]');
			const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

			const moveNewsPreview = (event, preview) => {
				const gap = 18;
				const padding = 12;
				const rect = preview.getBoundingClientRect();
				let left = event.clientX + gap;
				let top = event.clientY + gap;

				if (left + rect.width + padding > window.innerWidth) {
					left = event.clientX - rect.width - gap;
				}

				if (top + rect.height + padding > window.innerHeight) {
					top = event.clientY - rect.height - gap;
				}

				preview.style.transform = `translate3d(${clamp(left, padding, window.innerWidth - rect.width - padding)}px, ${clamp(top, padding, window.innerHeight - rect.height - padding)}px, 0)`;
			};

			newsPreviewCards.forEach((card) => {
				const preview = card.querySelector('[data-news-preview]');
				if (!preview) return;

				card.addEventListener('pointerenter', (event) => {
					moveNewsPreview(event, preview);
					preview.classList.remove('invisible', 'opacity-0');
					preview.classList.add('opacity-100');
				});

				card.addEventListener('pointermove', (event) => {
					moveNewsPreview(event, preview);
				});

				card.addEventListener('pointerleave', () => {
					preview.classList.add('invisible', 'opacity-0');
					preview.classList.remove('opacity-100');
				});
			});

			requestPhoneUpdate();
			window.addEventListener('scroll', requestPhoneUpdate, { passive: true });
			window.addEventListener('resize', requestPhoneUpdate);
		</script>
