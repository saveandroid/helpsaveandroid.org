---
import { Font } from 'astro:assets';
import '@/styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<meta
			name="description"
			content="A love letter to Android's freedom: safer phones, open apps, local anti-scam models, and user choice."
		/>
		<meta
			property="og:title"
			content="helpsaveandroid.org"
		/>
		<meta
			property="og:description"
			content="Android can be safer without becoming smaller. Help build the open path."
		/>
		<Font cssVariable="--font-serif" />
		<title>helpsaveandroid.org</title>
		<script is:inline>
			try {
				const storedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (storedTheme === 'dark' || (!storedTheme && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			} catch {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body>
		<header class="site-header">
			<a
				href="/"
				class="wordmark"
				aria-label="helpsaveandroid.org home"
			>
				helpsaveandroid<span>.</span>org
			</a>

			<nav
				class="header-nav"
				aria-label="Main"
			>
				<a href="#proposal">Proposal</a>
				<a href="#movement">Movement</a>
				<a href="#sources">Sources</a>
			</nav>

			<button
				id="theme-toggle"
				class="icon-button"
				type="button"
				aria-label="Toggle dark theme"
				aria-pressed="false"
			>
				<span
					class="sun-icon"
					aria-hidden="true"
				></span>
				<span
					class="moon-icon"
					aria-hidden="true"
				></span>
			</button>
		</header>

		<main>
			<section
				class="hero section-shell"
				aria-labelledby="hero-title"
			>
				<div class="hero-copy">
					<p class="eyebrow">Since January 1, 2025</p>
					<h1 id="hero-title">this much trust has been stolen.</h1>
					<p
						class="loss-counter"
						data-loss-counter
						data-annual-usd="442000000000"
						data-start-date="2025-01-01T00:00:00Z"
					>
						$0
					</p>
					<p
						class="counter-note"
						data-counter-note
					>
						<span data-counter-note-text
							>Counted linearly from a USD 442 billion annual scam-loss estimate.</span
						>
						<a
							href="#source-scam-loss"
							class="footnote-ref"
							aria-label="Source 1: scam loss estimate"
							>[1]</a
						>
					</p>

					<div
						class="metric-strip"
						aria-label="Campaign metrics"
					>
						<div>
							<strong data-loss-per-minute>$840,944</strong>
							<span>estimated per minute</span>
						</div>
						<div>
							<strong>23%</strong>
							<span>of surveyed adults lost money</span>
						</div>
						<div>
							<strong data-deadline-days>144</strong>
							<span>days to the first regional rollout</span>
						</div>
					</div>
				</div>

				<div
					class="hero-visual"
					aria-label="A phone protected by a local model and an open app index"
					role="img"
				>
					<div class="orbit orbit-one"></div>
					<div class="orbit orbit-two"></div>
					<div class="phone-frame">
						<div class="phone-speaker"></div>
						<div class="phone-screen">
							<div class="status-row">
								<span>offline guard</span>
								<span>local</span>
							</div>
							<div class="warning-panel">
								<span class="risk-dot"></span>
								<div>
									<strong>Voice Clone Detected</strong>
									<p>Known pressure pattern: urgency, secrecy, transfer.</p>
								</div>
							</div>
							<div class="model-panel">
								<div class="model-core">
									<span></span>
									<span></span>
									<span></span>
								</div>
								<div>
									<strong>Open Model</strong>
									<p>Runs on your phone. Learns from public tests.</p>
								</div>
							</div>
							<div class="store-panel">
								<span></span>
								<div>
									<strong>Open App Web</strong>
									<p>Source, checksums, permissions, human notes.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="floating-note note-left">safe for grandma</div>
					<div class="floating-note note-right">easy for geeks</div>
				</div>
			</section>

			<section class="letter-section">
				<div class="letter-copy">
					<p class="dear">Dear Android,</p>
					<p>
						We love you because you were the phone that still felt like a computer. You let people build
						strange little tools, share them with friends, repair their own workflows, and choose a different
						path when the official one did not fit.
					</p>
					<p>
						That freedom is not a loophole. It is the reason Android mattered. It is the reason a student can
						send an APK to a classroom, a mutual-aid group can distribute a crisis tool, a repair shop can
						keep old hardware useful, and a researcher can prove a safer design before a platform owner
						approves it.
					</p>
					<p>
						Scams are real. The harm is real. The phone call to a grandparent, the fake bank message, the
						cloned voice, the panicked transfer: none of this should be romanticized. But panic is a bad
						architect. A safer Android should protect people without making every developer ask one company
						for permission to exist.
					</p>
				</div>
			</section>

			<section
				class="fact-band"
				aria-labelledby="facts-title"
			>
				<div class="section-shell two-column">
					<div>
						<p class="eyebrow">The immediate problem</p>
						<h2 id="facts-title">Google is trying to help by adding a gate.</h2>
					</div>
					<div class="body-copy">
						<p>
							Google's announced Android developer verification program says that, starting September 2026,
							apps in selected regions must be registered by a verified developer to install on certified
							Android devices. Verification asks for personal details and may require official government ID.<a
								href="#source-developer-verification"
								class="footnote-ref"
								aria-label="Source 2: Android developer verification"
								>[2]</a
							>
						</p>
						<p>
							After public feedback, Google also described a power-user flow for unregistered apps: developer
							mode, a coercion check, restart and reauthentication, then a one-time one-day wait before the
							user can install unverified apps.<a
								href="#source-advanced-flow"
								class="footnote-ref"
								aria-label="Source 3: Google's advanced flow post"
								>[3]</a
							>
						</p>
						<p>
							We are glad Google is taking scams seriously. We are not glad that the default answer is
							identity, central registration, and friction controlled by the same actor that can be pressured
							to remove apps.<span class="citation-group"
								><a
									href="#source-aclu"
									class="footnote-ref"
									aria-label="Source 5: ACLU app-store control argument"
									>[5]</a
								><a
									href="#source-navalny"
									class="footnote-ref"
									aria-label="Source 6: Navalny voting app removal"
									>[6]</a
								><a
									href="#source-hkmap"
									class="footnote-ref"
									aria-label="Source 7: HKmap.live removal"
									>[7]</a
								></span
							>
						</p>
					</div>
				</div>
			</section>

			<section
				id="proposal"
				class="proposal section-shell"
				aria-labelledby="proposal-title"
			>
				<p class="eyebrow">A better Android</p>
				<h2 id="proposal-title">Protect the person. Keep the door open.</h2>
				<p class="section-lede">
					The solution has to be anonymous where anonymity matters, safe for grandma where safety matters, and
					easy for geeks where experimentation matters. Those are not competing requirements. They are the
					product spec.
				</p>

				<div class="principle-grid">
					<article>
						<span class="principle-number">01</span>
						<h3>Local Scam Intelligence</h3>
						<p>
							An open model runs on the device and looks for coercion: urgency, secrecy, impersonation,
							remote-control coaching, suspicious payment steps, and fake authority. It can warn without
							uploading private conversations to a cloud service.<a
								href="#source-gemma-mobile"
								class="footnote-ref"
								aria-label="Source 4: on-device mobile model reference"
								>[4]</a
							>
						</p>
					</article>
					<article>
						<span class="principle-number">02</span>
						<h3>An Open App Web</h3>
						<p>
							Useful open apps get a public page: source repository, reproducible build recipe, signing key
							history, checksum, permissions, maintainer notes, model screening, and human review. Anyone can
							mirror it.
						</p>
					</article>
					<article>
						<span class="principle-number">03</span>
						<h3>A Public Rehearsal Room</h3>
						<p>
							People submit synthetic scam attempts and see how close they got. The model should be so good
							that a 20 percent score feels impressive. Those attempts become public tests, not private
							danger.
						</p>
					</article>
				</div>
			</section>

			<section
				class="system-band"
				aria-labelledby="system-title"
			>
				<div class="section-shell">
					<div class="system-header">
						<div>
							<p class="eyebrow">One possible architecture</p>
							<h2 id="system-title">A World Wide Web for Android apps.</h2>
						</div>
						<p>
							Not a new monopoly. A small, boring, forkable set of files that phones, app stores, maintainers,
							and volunteers can all understand.
						</p>
					</div>

					<div class="pipeline">
						<div class="pipeline-step">
							<span>repo</span>
							<strong>Source Comes First</strong>
							<p>GitHub, GitLab, Codeberg, or a tarball. The code is inspectable.</p>
						</div>
						<div class="pipeline-step">
							<span>build</span>
							<strong>Artifacts Are Reproducible</strong>
							<p>Build instructions and checksums make quiet swaps harder.</p>
						</div>
						<div class="pipeline-step">
							<span>review</span>
							<strong>People Read the Risk</strong>
							<p>Permissions, network behavior, ownership, and privacy get notes.</p>
						</div>
						<div class="pipeline-step">
							<span>model</span>
							<strong>Machines Catch Patterns</strong>
							<p>Open classifiers flag malware traits and scam distribution tactics.</p>
						</div>
						<div class="pipeline-step">
							<span>choice</span>
							<strong>The User Decides</strong>
							<p>The warning is clear, the path is reversible, and the device remains theirs.</p>
						</div>
					</div>
				</div>
			</section>

			<section
				class="demo-section section-shell"
				aria-labelledby="demo-title"
			>
				<div>
					<p class="eyebrow">The anti-scam model</p>
					<h2 id="demo-title">The phone should notice pressure before the person breaks.</h2>
				</div>
				<div class="demo-grid">
					<div class="scenario-list">
						<button
							class="scenario-button is-active"
							type="button"
							data-scenario="bank"
						>
							Fake Bank Call
						</button>
						<button
							class="scenario-button"
							type="button"
							data-scenario="voice"
						>
							Cloned Voice Request
						</button>
						<button
							class="scenario-button"
							type="button"
							data-scenario="apk"
						>
							Remote Install Coaching
						</button>
					</div>
					<div
						class="scenario-panel"
						aria-live="polite"
					>
						<p class="scenario-label">local model readout</p>
						<h3 data-scenario-title>Likely Scam: 91%</h3>
						<p data-scenario-text>
							The caller creates urgency, asks for secrecy, and moves the person toward a transfer while
							keeping them on the phone.
						</p>
						<div class="score-meter">
							<span
								data-scenario-meter
								style="width: 91%"
							></span>
						</div>
						<ul data-scenario-flags>
							<li>urgency</li>
							<li>secrecy</li>
							<li>payment pressure</li>
						</ul>
					</div>
				</div>
			</section>

			<section
				class="comparison-section"
				aria-labelledby="comparison-title"
			>
				<div class="section-shell">
					<p class="eyebrow">The fork in the road</p>
					<h2 id="comparison-title">Two ways to answer the same fear.</h2>
					<div class="comparison-grid">
						<div class="comparison-heading freedom">Freedom-Preserving Path</div>
						<div class="comparison-heading gate">Google's Announced Path</div>
						<div>Import a readable trust file from any public host.</div>
						<div>Register apps to developer identities on certified devices.</div>
						<div>Warn on behavior, permissions, signatures, and coercion signals.</div>
						<div>Make verified identity the normal route for wide distribution.</div>
						<div>Let anonymous developers earn trust through source, builds, and review.</div>
						<div>Offer limited no-ID sharing for up to 20 authorized devices.</div>
						<div>Make the risky path understandable, quick to reverse, and user-owned.</div>
						<div>Put unregistered installs behind an advanced flow and one-day wait.</div>
					</div>
				</div>
			</section>

			<section
				id="movement"
				class="movement section-shell"
				aria-labelledby="movement-title"
			>
				<p class="eyebrow">Tests, allies, and enemies</p>
				<h2
					id="movement-title"
					class="pb-12"
				>
					The enemy is not Google. The enemy is (centralization + fear).
				</h2>
				<div class="movement-grid">
					<article>
						<h3>Small Win</h3>
						<p>
							Publish the first open manifest, seed it with real apps, and make one phone show a better
							warning than the platform does.
						</p>
					</article>
					<article>
						<h3>Local Work</h3>
						<p>
							Help families audit phones, TVs, tablets, and old devices. Keep the failsafe simple enough to
							explain at a kitchen table.
						</p>
					</article>
					<article>
						<h3>Social Work</h3>
						<p>
							Tell friends why device ownership matters. Ask reviewers, repair people, developers, and
							creators to show the safer open path in public.
						</p>
					</article>
					<article>
						<h3>Global Work</h3>
						<p>
							Push for rules that require sideloading, interoperability, repair, and appeal rights when a
							platform blocks software.
						</p>
					</article>
				</div>
			</section>

			<section class="resurrection">
				<div class="section-shell">
					<p class="eyebrow">Road back</p>
					<h2>Do not capitulate.</h2>
					<p>
						You bought the hardware. The whole thing should be yours for as long as it can run. From your
						phone to your tablet to your TV to your digital assistant, the default should be clear: your
						device can protect you without reporting every builder to a central gate.
					</p>
					<p>
						Android can become the platform that proves safety and freedom belong together. It can make scams
						harder, make open apps easier, and make ownership feel obvious again.
					</p>
				</div>
			</section>

			<section
				class="cta-section section-shell"
				aria-labelledby="cta-title"
			>
				<h2 id="cta-title">Help save Android by making the better answer real.</h2>
				<p>
					Send technical proposals, policy ideas, app review criteria, model tests, localization help, and
					small things that would make this safer for someone who is scared on the phone.
				</p>
				<div class="cta-actions">
					<a
						href="mailto:ideas@helpsaveandroid.org?subject=Idea%20to%20help%20save%20Android"
						class="primary-link"
						data-email-link
					>
						Send an idea
					</a>
					<a
						href="https://github.com/saveandroid/helpsaveandroid.org"
						class="secondary-link"
						target="_blank"
						rel="noreferrer"
					>
						Open the repo
					</a>
				</div>
			</section>

			<section
				id="sources"
				class="sources section-shell"
				aria-labelledby="sources-title"
			>
				<p class="eyebrow">Sources</p>
				<h2 id="sources-title">Facts this page relies on.</h2>
				<ol class="source-list">
					<li id="source-scam-loss">
						<a
							href="https://gasa.org/knowledge-base/blog/gasa-policy-agenda-2026"
							target="_blank"
							rel="noreferrer"
						>
							Global Anti-Scam Alliance Policy Agenda 2026
						</a>
						<span
							>Used for the USD 442 billion annual scam-loss estimate and surveyed-adult loss figures used in
							the hero metrics.</span
						>
					</li>
					<li id="source-developer-verification">
						<a
							href="https://developer.android.com/developer-verification"
							target="_blank"
							rel="noreferrer"
						>
							Android Developer Verification
						</a>
						<span>Used for Google's identity, package registration, and rollout timeline.</span>
					</li>
					<li id="source-advanced-flow">
						<a
							href="https://developer.android.com/blog/posts/android-developer-verification-balancing-openness-and-choice-with-safety"
							target="_blank"
							rel="noreferrer"
						>
							Google's Advanced Flow Post
						</a>
						<span>Used for the one-day wait and unregistered app flow.</span>
					</li>
					<li id="source-gemma-mobile">
						<a
							href="https://ai.google.dev/gemma/docs/integrations/mobile"
							target="_blank"
							rel="noreferrer"
						>
							Google AI for Developers: Deploy Gemma on Mobile Devices
						</a>
						<span>Used as a reference for deployable on-device language models on phones.</span>
					</li>
					<li id="source-aclu">
						<a
							href="https://www.aclu.org/news/free-speech/app-store-oligopoly"
							target="_blank"
							rel="noreferrer"
						>
							ACLU: Your Smartphone, Their Rules
						</a>
						<span>Used for the app-store control and censorship-risk argument.</span>
					</li>
					<li id="source-navalny">
						<a
							href="https://www.cnbc.com/2021/09/17/google-apple-remove-navalny-app-as-russian-elections-begin.html"
							target="_blank"
							rel="noreferrer"
						>
							Reuters via CNBC on Google and Apple Removing Navalny's Voting App
						</a>
						<span>Used as an example of app distribution pressure.</span>
					</li>
					<li id="source-hkmap">
						<a
							href="https://time.com/5696854/apple-hong-kong-map-app-removed/"
							target="_blank"
							rel="noreferrer"
						>
							TIME on Apple Removing HKmap.live
						</a>
						<span>Used as another example of app distribution pressure.</span>
					</li>
				</ol>
			</section>
		</main>

		<dialog
			id="email-dialog"
			class="email-dialog"
			aria-labelledby="email-dialog-title"
		>
			<div class="email-dialog-panel">
				<h2 id="email-dialog-title">Before you email</h2>
				<p>
					Messages to ideas@helpsaveandroid.org will be reviewed by volunteers. Please do not send passwords,
					private data, or live scam material.
				</p>
				<div class="dialog-actions">
					<a
						href="mailto:ideas@helpsaveandroid.org?subject=Idea%20to%20help%20save%20Android"
						class="primary-link"
						data-email-continue
					>
						Continue to email
					</a>
					<button
						type="button"
						class="secondary-link"
						data-email-cancel
					>
						Cancel
					</button>
				</div>
			</div>
		</dialog>

		<div
			id="link-preview"
			class="link-preview"
			hidden
		>
			<canvas
				width="320"
				height="142"
				aria-hidden="true"
			></canvas>
			<div>
				<p
					class="preview-site"
					data-preview-site
				>
				</p>
				<p
					class="preview-title"
					data-preview-title
				>
				</p>
				<p
					class="preview-text"
					data-preview-text
				>
				</p>
			</div>
		</div>

		<script>
			const siteHeader = document.querySelector<HTMLElement>('.site-header');
			const themeToggle = document.querySelector<HTMLButtonElement>('#theme-toggle');
			const lossCounter = document.querySelector<HTMLElement>('[data-loss-counter]');
			const counterNoteText = document.querySelector<HTMLElement>('[data-counter-note-text]');
			const lossPerMinute = document.querySelector<HTMLElement>('[data-loss-per-minute]');
			const deadlineDays = document.querySelector<HTMLElement>('[data-deadline-days]');
			const emailLink = document.querySelector<HTMLAnchorElement>('[data-email-link]');
			const emailDialog = document.querySelector<HTMLDialogElement>('#email-dialog');
			const emailCancel = document.querySelector<HTMLButtonElement>('[data-email-cancel]');
			const emailContinue = document.querySelector<HTMLAnchorElement>('[data-email-continue]');
			const scenarioButtons = document.querySelectorAll<HTMLButtonElement>('[data-scenario]');
			const scenarioTitle = document.querySelector<HTMLElement>('[data-scenario-title]');
			const scenarioText = document.querySelector<HTMLElement>('[data-scenario-text]');
			const scenarioMeter = document.querySelector<HTMLElement>('[data-scenario-meter]');
			const scenarioFlags = document.querySelector<HTMLElement>('[data-scenario-flags]');
			const preview = document.querySelector<HTMLElement>('#link-preview');
			const previewCanvas = preview?.querySelector<HTMLCanvasElement>('canvas');
			const previewSite = preview?.querySelector<HTMLElement>('[data-preview-site]');
			const previewTitle = preview?.querySelector<HTMLElement>('[data-preview-title]');
			const previewText = preview?.querySelector<HTMLElement>('[data-preview-text]');

			const syncThemeState = () => {
				themeToggle?.setAttribute(
					'aria-pressed',
					String(document.documentElement.classList.contains('dark')),
				);
			};

			syncThemeState();

			const setupHeaderReveal = () => {
				if (!siteHeader) {
					return;
				}

				let lastScrollY = window.scrollY;
				let upwardTravel = 0;
				let ticking = false;

				const syncHeaderHeight = () => {
					document.documentElement.style.setProperty('--site-header-height', `${siteHeader.offsetHeight}px`);
				};

				const showHeader = () => {
					siteHeader.classList.remove('is-hidden');
				};

				const hideHeader = () => {
					siteHeader.classList.add('is-hidden');
				};

				const updateHeader = () => {
					const currentY = Math.max(0, window.scrollY);
					const delta = currentY - lastScrollY;

					if (currentY <= 4) {
						upwardTravel = 0;
						showHeader();
					} else if (delta > 0) {
						upwardTravel = 0;
						hideHeader();
					} else if (delta < 0) {
						upwardTravel += Math.abs(delta);
						if (upwardTravel >= 18) {
							showHeader();
						}
					}

					lastScrollY = currentY;
					ticking = false;
				};

				syncHeaderHeight();
				window.addEventListener('resize', syncHeaderHeight);
				window.addEventListener(
					'scroll',
					() => {
						if (!ticking) {
							window.requestAnimationFrame(updateHeader);
							ticking = true;
						}
					},
					{ passive: true },
				);
			};

			themeToggle?.addEventListener('click', () => {
				const isDark = document.documentElement.classList.toggle('dark');
				try {
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				} catch {
					return;
				}
				syncThemeState();
			});

			const scenarios = {
				bank: {
					title: 'Likely Scam: 91%',
					text: 'The caller creates urgency, asks for secrecy, and moves the person toward a transfer while keeping them on the phone.',
					score: 91,
					flags: ['urgency', 'secrecy', 'payment pressure'],
				},
				voice: {
					title: 'Likely Scam: 87%',
					text: 'The message sounds personal, but the request is unusual, time-limited, and asks for money through a channel the family does not normally use.',
					score: 87,
					flags: ['voice clone risk', 'new payment route', 'emotional pressure'],
				},
				apk: {
					title: 'Likely Scam: 96%',
					text: 'A stranger is coaching the user to change security settings, install an app, and keep the session active while they watch.',
					score: 96,
					flags: ['remote coaching', 'install pressure', 'screen sharing'],
				},
			};

			scenarioButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const scenario = scenarios[button.dataset.scenario as keyof typeof scenarios];
					if (!scenario || !scenarioTitle || !scenarioText || !scenarioMeter || !scenarioFlags) {
						return;
					}

					scenarioButtons.forEach((item) => item.classList.toggle('is-active', item === button));
					scenarioTitle.textContent = scenario.title;
					scenarioText.textContent = scenario.text;
					scenarioMeter.style.width = `${scenario.score}%`;
					scenarioFlags.replaceChildren(
						...scenario.flags.map((flag) => {
							const item = document.createElement('li');
							item.textContent = flag;
							return item;
						}),
					);
				});
			});

			emailLink?.addEventListener('click', (event) => {
				if (!emailDialog || typeof emailDialog.showModal !== 'function') {
					return;
				}

				event.preventDefault();
				emailDialog.showModal();
			});

			emailCancel?.addEventListener('click', () => {
				emailDialog?.close();
			});

			emailContinue?.addEventListener('click', () => {
				emailDialog?.close();
			});

			emailDialog?.addEventListener('click', (event) => {
				if (event.target === emailDialog) {
					emailDialog.close();
				}
			});

			const currencyByRegion: Record<string, string> = {
				US: 'USD',
				CA: 'CAD',
				MX: 'MXN',
				BR: 'BRL',
				GB: 'GBP',
				IE: 'EUR',
				FR: 'EUR',
				DE: 'EUR',
				ES: 'EUR',
				IT: 'EUR',
				NL: 'EUR',
				PT: 'EUR',
				BE: 'EUR',
				AT: 'EUR',
				FI: 'EUR',
				GR: 'EUR',
				IN: 'INR',
				ID: 'IDR',
				SG: 'SGD',
				TH: 'THB',
				JP: 'JPY',
				KR: 'KRW',
				AU: 'AUD',
				NZ: 'NZD',
				ZA: 'ZAR',
				NG: 'NGN',
				KE: 'KES',
				PH: 'PHP',
				MY: 'MYR',
				CN: 'CNY',
				HK: 'HKD',
				TW: 'TWD',
				AE: 'AED',
				SA: 'SAR',
			};

			const getRegion = () => {
				try {
					const locale = new Intl.Locale(navigator.language);
					return locale.region ?? 'US';
				} catch {
					return 'US';
				}
			};

			const getExchangeRate = async (currency: string) => {
				if (currency === 'USD') {
					return 1;
				}

				try {
					const cached = sessionStorage.getItem(`usd-rate:${currency}`);
					if (cached) {
						const parsed = JSON.parse(cached);
						if (Date.now() - parsed.time < 12 * 60 * 60 * 1000 && Number.isFinite(parsed.rate)) {
							return parsed.rate;
						}
					}
				} catch {
					// Private browsing modes can block storage; exchange lookup can still continue.
				}

				const controller = new AbortController();
				const timeout = window.setTimeout(() => controller.abort(), 1800);

				try {
					const response = await fetch(`https://api.frankfurter.app/latest?from=USD&to=${currency}`, {
						signal: controller.signal,
					});
					const data = await response.json();
					const rate = Number(data?.rates?.[currency]);
					if (Number.isFinite(rate) && rate > 0) {
						try {
							sessionStorage.setItem(`usd-rate:${currency}`, JSON.stringify({ rate, time: Date.now() }));
						} catch {
							// The live rate still works for this page view.
						}
						return rate;
					}
				} catch {
					return 1;
				} finally {
					window.clearTimeout(timeout);
				}

				return 1;
			};

			const setupLossCounter = async () => {
				if (!lossCounter) {
					return;
				}

				const annualUsd = Number(lossCounter.dataset.annualUsd);
				const startDate = new Date(lossCounter.dataset.startDate ?? '').getTime();
				if (!Number.isFinite(annualUsd) || !Number.isFinite(startDate)) {
					return;
				}

				const locale = navigator.language || 'en-US';
				const region = getRegion();
				const currency = currencyByRegion[region] ?? 'USD';
				const rate = await getExchangeRate(currency);
				const hasLocalRate = currency === 'USD' || rate !== 1;
				const formatter = new Intl.NumberFormat(locale, {
					style: 'currency',
					currency: hasLocalRate ? currency : 'USD',
					maximumFractionDigits: 0,
				});
				const msPerYear = 365 * 24 * 60 * 60 * 1000;
				const msPerMinute = 60 * 1000;
				const openTime = Date.now();
				const usdAtOpen = Math.max(0, ((openTime - startDate) / msPerYear) * annualUsd);
				const roundedUsdAtOpen = Math.floor(usdAtOpen / 100000000) * 100000000;
				const usdPerMs = annualUsd / msPerYear;
				const displayRate = hasLocalRate ? rate : 1;
				let running = false;
				let lastFrame = 0;

				const formatAmount = (usd: number) => formatter.format(usd * displayRate);
				const render = () => {
					const elapsed = running ? Date.now() - openTime : 0;
					lossCounter.textContent = formatAmount(roundedUsdAtOpen + elapsed * usdPerMs);
				};
				const tick = (time: number) => {
					if (time - lastFrame > 240) {
						render();
						lastFrame = time;
					}
					if (running) {
						requestAnimationFrame(tick);
					}
				};
				const start = () => {
					if (running || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
						render();
						return;
					}
					running = true;
					lossCounter.classList.add('is-live');
					requestAnimationFrame(tick);
				};

				render();

				if (counterNoteText) {
					counterNoteText.textContent = hasLocalRate
						? `Shown in ${currency}. Counted from a rounded page-open number using a USD 442 billion annual estimate.`
						: 'Shown in USD because a local exchange rate was unavailable. Counted from a rounded page-open number.';
				}

				if (lossPerMinute) {
					lossPerMinute.textContent = formatAmount((annualUsd / msPerYear) * msPerMinute);
				}

				window.addEventListener('scroll', start, { passive: true, once: true });
				window.addEventListener('pointerdown', start, { passive: true, once: true });
			};

			const setupDeadline = () => {
				if (!deadlineDays) {
					return;
				}
				const deadline = new Date('2026-09-30T00:00:00Z').getTime();
				const days = Math.max(0, Math.ceil((deadline - Date.now()) / (24 * 60 * 60 * 1000)));
				deadlineDays.textContent = String(days);
			};

			const drawPreviewCanvas = (site: string, title: string) => {
				const context = previewCanvas?.getContext('2d');
				if (!context || !previewCanvas) {
					return;
				}

				context.clearRect(0, 0, previewCanvas.width, previewCanvas.height);
				context.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--paper');
				context.fillRect(0, 0, previewCanvas.width, previewCanvas.height);
				context.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--accent-soft');
				context.fillRect(0, 0, previewCanvas.width, 36);
				context.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--line-strong');
				for (let x = 20; x < previewCanvas.width; x += 34) {
					context.fillRect(x, 60, 20, 5);
					context.fillRect(x, 82, 42, 5);
					context.fillRect(x, 104, 28, 5);
				}
				context.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--ink');
				context.font = '700 15px serif';
				context.fillText(site, 18, 23);
				context.font = '700 20px serif';
				context.fillText(title.slice(0, 26), 18, 132);
			};

			const positionPreview = (x: number, y: number) => {
				if (!preview) {
					return;
				}
				const margin = 18;
				const rect = preview.getBoundingClientRect();
				const left = Math.min(window.innerWidth - rect.width - margin, Math.max(margin, x + 18));
				const top = Math.min(window.innerHeight - rect.height - margin, Math.max(margin, y + 18));
				preview.style.left = `${left}px`;
				preview.style.top = `${top}px`;
			};

			const showPreview = (link: HTMLElement, x: number, y: number) => {
				if (!preview || !previewTitle || !previewText || !previewSite) {
					return;
				}

				const title = link.dataset.previewTitle ?? link.textContent?.trim() ?? 'Source';
				const site = link.dataset.previewSite ?? new URL((link as HTMLAnchorElement).href).hostname;
				const text = link.dataset.previewText ?? '';
				preview.hidden = false;
				previewTitle.textContent = title;
				previewSite.textContent = site;
				previewText.textContent = text;
				drawPreviewCanvas(site, title);
				positionPreview(x, y);
			};

			const hidePreview = () => {
				if (preview) {
					preview.hidden = true;
				}
			};

			let armedTouchLink: HTMLAnchorElement | null = null;

			document.querySelectorAll<HTMLAnchorElement>('.source-link').forEach((link) => {
				link.addEventListener('pointerenter', (event) => {
					showPreview(link, event.clientX, event.clientY);
				});
				link.addEventListener('pointermove', (event) => {
					positionPreview(event.clientX, event.clientY);
				});
				link.addEventListener('pointerleave', hidePreview);
				link.addEventListener('focus', () => {
					const rect = link.getBoundingClientRect();
					showPreview(link, rect.left, rect.bottom);
				});
				link.addEventListener('blur', hidePreview);
				link.addEventListener('click', (event) => {
					if (!window.matchMedia('(hover: none)').matches || armedTouchLink === link) {
						return;
					}
					event.preventDefault();
					armedTouchLink = link;
					const rect = link.getBoundingClientRect();
					showPreview(link, rect.left, rect.bottom);
					window.setTimeout(() => {
						armedTouchLink = null;
					}, 4200);
				});
			});

			setupDeadline();
			setupLossCounter();
			setupHeaderReveal();
		</script>
	</body>
</html>
