---
import { Font } from 'astro:assets';
import acluPreviewImage from '@/assets/placeholder-aclu.png';
import guardianPreviewImage from '@/assets/placeholder-guardian.png';
import techradarPreviewImage from '@/assets/placeholder-techradar.png';
import PhoneMockup from '@/components/phone-mockup.astro';
import '@/styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<meta
			name="description"
			content="Android can be safer without becoming smaller. Help build the open path."
		/>
		<meta
			property="og:title"
			content="helpsaveandroid.org"
		/>
		<meta
			property="og:description"
			content="Android can be safer without becoming smaller. Help build the open path."
		/>
		<Font cssVariable="--font-serif" />
		<title>helpsaveandroid.org</title>
	</head>
	<body>
		<a
			href="#top"
			class="side-wordmark text-(--muted)/50! hover:text-(--ink)! group"
			aria-label="helpsaveandroid.org home"
		>
			helpsaveandroid<span class="group-hover:text-(--accent) transition-colors">.</span>org
		</a>

		<main
			id="top"
			class="relative overflow-x-clip"
		>
			<section
				class="relative mx-auto grid max-w-7xl px-5 sm:px-8 md:grid-cols-[minmax(0,1fr)_minmax(19rem,27rem)] md:gap-16 md:px-12 xl:gap-24"
			>
				<div class="relative z-10">
					<div class="pointer-events-none sticky top-0 z-0 -mb-[100svh] h-svh overflow-hidden md:hidden">
						<div class="absolute inset-x-0 -bottom-[11rem] flex justify-center sm:-bottom-[13.25rem]">
							<PhoneMockup size="compact" />
						</div>
					</div>

					<section
						class="snap-panel relative z-10 flex min-h-screen items-start pb-20 pt-8 sm:pt-10 md:items-center md:pb-24 md:pt-24"
					>
						<div class="max-w-3xl">
							<p class="type-body italic text-(--ink)">Since the beginning of last year,</p>
							<div
								class="type-heading mt-5 max-w-full whitespace-nowrap text-(--ink) tabular-nums"
								data-loss-counter
							>
								$0
							</div>
							<p class="type-body text-end lg:text-start lg:pl-69 mt-6 max-w-2xl italic text-(--ink)">
								has been ruined and lost to scams.
							</p>

							<div class="type-body mt-11 max-w-2xl space-y-5 text-(--ink)">
								<p>
									Google is trying to fix this, but they're doing so by tightening their control of Android.
								</p>
								<p class="text-(--ink)">What might a better approach, and a better Android look like?</p>
							</div>
						</div>
					</section>

					<section
						id="solution"
						class="snap-panel relative z-10 flex min-h-screen items-start pb-24 pt-12 sm:pt-16 md:items-center md:py-24"
						data-people-trigger
					>
						<div class="max-w-3xl">
							<p class="type-subheading max-w-2xl text-(--ink)">The solution has to work for everyone.</p>
							<p class="type-body mt-8 text-(--ink)">It has to be:</p>
							<ol class="type-body mt-4 ml-6 grid text-(--ink)">
								<li class="flex items-baseline gap-4 py-1">
									<span class="text-(--accent-strong)">1.</span>
									<span>safe for grandma,</span>
								</li>
								<li class="flex items-baseline gap-4 py-1">
									<span class="text-(--accent-strong)">2.</span>
									<span>easy for geeks, and</span>
								</li>
								<li class="flex items-baseline gap-4 py-1">
									<span class="text-(--accent-strong)">3.</span>
									<span>anonymous for developers.</span>
								</li>
							</ol>
						</div>
					</section>
				</div>

				<aside class="pointer-events-none sticky top-0 hidden h-screen items-center justify-center md:flex">
					<PhoneMockup />
				</aside>
			</section>

			<section
				class="snap-panel relative z-10 border-t border-(--line) bg-(--paper-raised) px-5 pb-28 pt-10 sm:px-8 lg:px-12"
			>
				<div class="mx-auto max-w-3xl">
					<p class="type-body text-(--ink)">
						We propose creating a local and open language model to detect scams, for everyone.
					</p>

					<div class="my-16 grid gap-4 lg:-ml-36 lg:w-[calc(100%+18rem)] lg:grid-cols-2">
						<div
							class="grid min-h-80 place-items-center rounded-lg border border-dashed border-(--line-strong) bg-(--paper) p-6 text-center shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-subheading text-(--muted)">[anti-scam model]</p>
						</div>
						<div
							class="grid min-h-80 place-items-center rounded-lg border border-dashed border-(--line-strong) bg-(--paper) p-6 text-center shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-subheading text-(--muted)">[an open app store]</p>
						</div>
					</div>

					<div class="type-body space-y-5 text-(--ink)">
						<p>
							You can now run local language models on your phone. So, you could have one that's just
							protecting you from ever sophisticated scamming attempts.
						</p>
						<p class="mb-1">
							Everyone can contribute to the model, and a fun activity is seeing how close you can get to
							scamming; you get a score on how close you got.
						</p>
						<p class="text-[clamp(1rem,1.25vw,1.12rem)] leading-relaxed italic">
							(But, the model is so good that you never really get close; like 20% close is a really good
							score.)
						</p>
						<p class="mb-2.5">Also, what about creating a "World Wide Web", where,</p>
						<ul class="ml-16 mb-2.5 grid list-disc gap-1">
							<li>developers can give away useful and open apps,</li>
							<li>with open-source code,</li>
							<li>and automatic filtering,</li>
						</ul>
						<p>which are personally checked by actual people?</p>
						<p>
							We think that creating a world without scams becomes possible with open and transparent
							software.
						</p>
					</div>

					<div
						class="my-16 grid min-h-96 place-items-center rounded-lg border border-dashed border-(--line-strong) bg-(--paper) p-6 text-center shadow-[0_1.2rem_2.4rem_var(--page-shadow)] lg:-ml-36 lg:w-[calc(100%+18rem)]"
					>
						<p class="type-subheading text-(--muted)">[a world wide web of open-source applications]</p>
					</div>

					<p class="type-body text-(--ink)">
						There are also other very good reasons we're doing this, mainly to do with software freedom, but
						also that Google has a documented history of removing apps when regimes have asked.
					</p>

					<div class="my-14 flex flex-col gap-10 lg:-ml-36 lg:w-[calc(100%+18rem)]">
						<article
							class="relative w-full max-w-3xl"
							data-news-preview-card
						>
							<a
								href="https://www.aclu.org/news/free-speech/app-store-oligopoly"
								target="_blank"
								rel="noreferrer"
								class="block rounded-lg border border-(--accent) bg-(--accent-strong) p-6 text-white shadow-[0_1.2rem_2.4rem_var(--page-shadow)] transition-transform duration-300 hover:-translate-y-1 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--ink)"
							>
								<p class="text-sm font-semibold uppercase tracking-[0.12em] text-white/72">ACLU</p>
								<h3 class="type-subheading mt-3">Your Smartphone, Their Rules</h3>
								<p class="type-body mt-4 text-white/82">
									How centralized app stores can enable corporate-government censorship.
								</p>
							</a>
							<div
								class="pointer-events-none invisible fixed left-0 top-0 z-50 w-80 overflow-hidden rounded-md border border-(--line) bg-white opacity-0 shadow-[0_1rem_2rem_rgba(21,22,17,.28)] transition-opacity duration-150 sm:w-96"
								data-news-preview
							>
								<img
									src={acluPreviewImage.src}
									alt=""
									loading="lazy"
									decoding="async"
									class="block h-auto w-full bg-white border-2 border-(--line) rounded-md"
								/>
							</div>
						</article>

						<article
							class="relative ml-auto w-full max-w-3xl"
							data-news-preview-card
						>
							<a
								href="https://www.theguardian.com/world/2021/sep/17/apple-and-google-accused-of-political-censorship-over-alexei-navalny-app"
								target="_blank"
								rel="noreferrer"
								class="block rounded-lg border border-(--accent) bg-(--accent-strong) p-6 text-white shadow-[0_1.2rem_2.4rem_var(--page-shadow)] transition-transform duration-300 hover:-translate-y-1 focus-visible:outline focus-visible:outline-offset-4 focus-visible:outline-(--ink)"
							>
								<p class="text-sm font-semibold uppercase tracking-[0.12em] text-white/72">The Guardian</p>
								<h3 class="type-subheading mt-3">Apple and Google Accused of Political Censorship</h3>
								<p class="type-body mt-4 text-white/82">
									Navalny supporters said the companies deleted a tactical voting app after Kremlin pressure.
								</p>
							</a>
							<div
								class="pointer-events-none invisible fixed left-0 top-0 z-50 w-80 overflow-hidden rounded-md border border-(--line) bg-white opacity-0 shadow-[0_1rem_2rem_rgba(21,22,17,.28)] transition-opacity duration-150 sm:w-96"
								data-news-preview
							>
								<img
									src={guardianPreviewImage.src}
									alt=""
									loading="lazy"
									decoding="async"
									class="block h-auto w-full bg-white border-2 border-(--line) rounded-md"
								/>
							</div>
						</article>

						<article
							class="relative w-full max-w-3xl"
							data-news-preview-card
						>
							<a
								href="https://www.techradar.com/vpn/vpn-privacy-security/russia-orders-apple-and-google-to-remove-important-stories-an-investigative-media-app-that-works-without-a-vpn-leaving-russians-without-a-key-source-for-accessing-uncensored-news"
								target="_blank"
								rel="noreferrer"
								class="block rounded-lg border border-(--accent) bg-(--accent-strong) p-6 text-white shadow-[0_1.2rem_2.4rem_var(--page-shadow)] transition-transform duration-300 hover:-translate-y-1 focus-visible:outline focus-visible:outline-offset-4 focus-visible:outline-(--ink)"
							>
								<p class="text-sm font-semibold uppercase tracking-[0.12em] text-white/72">TechRadar</p>
								<h3 class="type-subheading mt-3">
									Russia Orders Apple and Google to Remove Important Stories
								</h3>
								<p class="type-body mt-4 text-white/82">
									Roskomnadzor targeted an investigative news app built to work inside Russia without a VPN.
								</p>
							</a>
							<div
								class="pointer-events-none invisible fixed left-0 top-0 z-50 w-80 overflow-hidden rounded-md border border-(--line) bg-white opacity-0 shadow-[0_1rem_2rem_rgba(21,22,17,.28)] transition-opacity duration-150 sm:w-96"
								data-news-preview
							>
								<img
									src={techradarPreviewImage.src}
									alt=""
									loading="lazy"
									decoding="async"
									class="block h-auto w-full bg-white border-2 border-(--line) rounded-md"
								/>
							</div>
						</article>
					</div>

					<div class="type-body space-y-5 text-(--ink)">
						<p>
							This isn't something we can achieve alone. We have made a little open thing online, and you can
							suggest your best ideas to help save Android. Instead of mandating that Android developers
							identify themselves, solving the problem must be (at a minimum):
						</p>
						<ol class="ml-6 grid text-(--ink)">
							<li class="flex items-baseline gap-4 py-1">
								<span class="text-(--accent-strong)">1.</span>
								<span>safe for grandma,</span>
							</li>
							<li class="flex items-baseline gap-4 py-1">
								<span class="text-(--accent-strong)">2.</span>
								<span>easy for geeks, and</span>
							</li>
							<li class="flex items-baseline gap-4 py-1">
								<span class="text-(--accent-strong)">3.</span>
								<span>anonymous for developers</span>
							</li>
						</ol>
						<p>
							Anyone can contribute ideas, and you're welcome to
							<a
								href="mailto:ideas@helpsaveandroid.org"
								class="text-(--ink) font-semibold underline decoration-(--accent-strong) decoration-2 hover:decoration-4 underline-offset-4"
							>
								send an email</a
							>
							or
							<a
								href="https://github.com/saveandroid/helpsaveandroid.org"
								target="_blank"
								rel="noreferrer"
								class="text-(--ink) font-semibold underline decoration-(--accent-strong) hover:decoration-4 decoration-2 underline-offset-4"
							>
								discuss approaches on GitHub</a
							>.
						</p>
					</div>

					<div class="mx-auto my-20 flex justify-center">
						<img
							src="/divider.svg"
							alt=""
							class="h-14 w-auto opacity-80"
							loading="lazy"
						/>
					</div>

					<section
						aria-labelledby="scenario-heading"
						class="type-body space-y-7 text-(--ink)"
					>
						<h2
							id="scenario-heading"
							class="type-subheading text-center text-(--ink)"
						>
							A Scenario...
						</h2>

						<p>
							Let's imagine that the internet gets censored, and an anonymous developer builds chatting using
							Bluetooth.
						</p>

						<div
							class="grid min-h-80 place-items-center rounded-lg border border-dashed border-(--line-strong) bg-(--paper) p-6 text-center shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-body font-semibold! text-(--muted)">
								[developer sitting in the window programming]
							</p>
						</div>

						<p>
							You can relay messages between people, and share what you're thinking about in your
							neighbourhood, and they relay around the world.
						</p>

						<div
							class="grid min-h-80 place-items-center rounded-lg border border-dashed border-(--line-strong) bg-(--paper) p-6 text-center shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-body font-semibold! text-(--muted)">
								[how the app works and messaging around the world]
							</p>
						</div>

						<p>
							Google has to comply with the government, and takes down the app; they also give the government
							the developers real name.
						</p>

						<div
							class="grid min-h-80 place-items-center rounded-lg border border-dashed border-(--line-strong) bg-(--paper) p-6 text-center shadow-[0_1.2rem_2.4rem_var(--page-shadow)]"
						>
							<p class="type-body font-semibold! text-(--muted)">
								[developer gets a knock on the door from people in suits]
							</p>
						</div>

						<p>
							It is also very possible that, at some point, there is a digital pre-requisite checking the
							functionality of your application and doesn't even allow you to build it in the first place.
						</p>

						<p>
							Unless we do something, the first step towards this future is in
							<span
								class="font-semibold tabular-nums text-(--ink)"
								data-days-until-september
							>
								114</span
							>
							<span class="font-semibold text-(--ink)">days</span>.
						</p>
					</section>
				</div>
			</section>
		</main>

		<script is:inline>
			const scamStart = new Date('2025-01-01T00:00:00.000Z').getTime();
			const annualLossUsd = 400_000_000_000;
			const msPerYear = 365 * 24 * 60 * 60 * 1000;
			const formatter = new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 0,
			});

			const counters = document.querySelectorAll('[data-loss-counter]');
			const loadAt = performance.now();

			const lossAt = (time) => Math.max(0, ((time - scamStart) / msPerYear) * annualLossUsd);
			const easeOut = (value) => 1 - Math.pow(1 - value, 3);

			const renderCounter = (now) => {
				const progress = Math.min(1, (now - loadAt) / 1800);
				const displayValue = lossAt(Date.now()) * easeOut(progress);
				counters.forEach((counter) => {
					counter.textContent = formatter.format(displayValue);
				});
				requestAnimationFrame(renderCounter);
			};

			if (counters.length) {
				requestAnimationFrame(renderCounter);
			}

			const daysUntilSeptember = document.querySelector('[data-days-until-september]');
			if (daysUntilSeptember) {
				const targetDate = new Date('2026-09-01T00:00:00');
				const startOfToday = new Date();
				startOfToday.setHours(0, 0, 0, 0);
				const msPerDay = 24 * 60 * 60 * 1000;
				daysUntilSeptember.textContent = Math.max(
					0,
					Math.ceil((targetDate.getTime() - startOfToday.getTime()) / msPerDay),
				).toLocaleString('en-US');
			}

			const phones = document.querySelectorAll('[data-phone]');
			const peopleTrigger = document.querySelector('[data-people-trigger]');
			let ticking = false;
			let phoneReady = false;

			const updatePhoneMode = () => {
				if (!peopleTrigger) return;
				const shouldShowPeople = peopleTrigger.getBoundingClientRect().top < window.innerHeight * 0.58;
				phones.forEach((phone) => {
					phone.setAttribute('data-mode', shouldShowPeople ? 'people' : 'chat');
				});
				if (!phoneReady) {
					phoneReady = true;
					requestAnimationFrame(() => {
						phones.forEach((phone) => phone.classList.add('is-ready'));
					});
				}
				ticking = false;
			};

			const requestPhoneUpdate = () => {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(updatePhoneMode);
			};

			const newsPreviewCards = document.querySelectorAll('[data-news-preview-card]');
			const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

			const moveNewsPreview = (event, preview) => {
				const gap = 18;
				const padding = 12;
				const rect = preview.getBoundingClientRect();
				let left = event.clientX + gap;
				let top = event.clientY + gap;

				if (left + rect.width + padding > window.innerWidth) {
					left = event.clientX - rect.width - gap;
				}

				if (top + rect.height + padding > window.innerHeight) {
					top = event.clientY - rect.height - gap;
				}

				preview.style.transform = `translate3d(${clamp(left, padding, window.innerWidth - rect.width - padding)}px, ${clamp(top, padding, window.innerHeight - rect.height - padding)}px, 0)`;
			};

			newsPreviewCards.forEach((card) => {
				const preview = card.querySelector('[data-news-preview]');
				if (!preview) return;

				card.addEventListener('pointerenter', (event) => {
					moveNewsPreview(event, preview);
					preview.classList.remove('invisible', 'opacity-0');
					preview.classList.add('opacity-100');
				});

				card.addEventListener('pointermove', (event) => {
					moveNewsPreview(event, preview);
				});

				card.addEventListener('pointerleave', () => {
					preview.classList.add('invisible', 'opacity-0');
					preview.classList.remove('opacity-100');
				});
			});

			requestPhoneUpdate();
			window.addEventListener('scroll', requestPhoneUpdate, { passive: true });
			window.addEventListener('resize', requestPhoneUpdate);
		</script>
	</body>
</html>
