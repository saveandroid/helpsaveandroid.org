---
import RepresentativeVotingIsland from './representative-voting.tsx';

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<section
	id="representatives"
	class="relative z-10 my-20 bg-(--paper-raised) py-10 sm:my-24 sm:py-12 lg:-ml-36 lg:w-[calc(100%+18rem)]"
	aria-labelledby="representatives-heading"
>
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<div class="mx-auto mb-7 max-w-4xl text-center">
			<div>
				<h2
					id="representatives-heading"
					class="type-subheading mt-2 text-(--ink)"
				>
					Who should hear from the internet?
				</h2>
				<p class="text-base leading-relaxed text-(--muted)">
					You can upvote many, and star your favorite. You stay anonymous at all times.
				</p>
			</div>
		</div>

		<div>
			<RepresentativeVotingIsland
				client:load
				siteKey={siteKey}
			/>
		</div>
	</div>
</section>

<script
	is:inline
	src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
	async
	defer
></script>
