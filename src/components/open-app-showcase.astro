---
import airguardIcon from '@/assets/app-airguard.png';
import gritIcon from '@/assets/app-grit.png';
import openreadsIcon from '@/assets/app-openreads.png';
import paperknifeIcon from '@/assets/app-paperknife.png';
import unittoIcon from '@/assets/app-unitto.png';

const apps = [
	{
		name: 'Unitto',
		note: 'A calculator, unit and currency converter.',
		href: 'https://f-droid.org/packages/com.sadellie.unitto/',
		icon: unittoIcon,
		accent: '#2f9355',
		tilt: '-3deg',
		rise: '1.5rem',
	},
	{
		name: 'Grit',
		note: 'A to-do list and daily tracker to visualize your progress.',
		href: 'https://f-droid.org/en/packages/com.shub39.grit/',
		icon: gritIcon,
		accent: '#e7d58b',
		tilt: '2deg',
		rise: '-0.75rem',
	},
	{
		name: 'PaperKnife+',
		note: 'A privacy-first PDF utility to merge, split, etc.',
		href: 'https://f-droid.org/packages/com.paperknifeplus.app/',
		icon: paperknifeIcon,
		accent: '#ef3155',
		tilt: '-1.2deg',
		rise: '0.6rem',
	},
	{
		name: 'Openreads',
		note: 'A private book organizer and reading progress tracker.',
		href: 'https://f-droid.org/en/packages/software.mdev.bookstracker/',
		icon: openreadsIcon,
		accent: '#1d8d86',
		tilt: '3.2deg',
		rise: '-1.15rem',
	},
	{
		name: 'AirGuard',
		note: 'Be aware of Apple AirTags stalking you, on Android .',
		href: 'https://f-droid.org/packages/de.seemoo.at_tracking_detection/',
		icon: airguardIcon,
		accent: '#a240e5',
		tilt: '-2.1deg',
		rise: '1rem',
	},
];
---

<section
	class="open-app-showcase relative z-10 my-16 lg:-ml-36 lg:w-[calc(100%+18rem)]"
	aria-label="Examples of open source apps"
>
	<div class="open-app-strip">
		{
			apps.map((app) => (
				<a
					href={app.href}
					target="_blank"
					rel="noopener noreferrer"
					class="open-app-card"
					style={`--tilt: ${app.tilt}; --rise: ${app.rise}; --app-accent: ${app.accent};`}
				>
					<img
						src={app.icon.src}
						width={app.icon.width}
						height={app.icon.height}
						alt=""
						class="open-app-icon"
						loading="lazy"
					/>
					<h3>{app.name}</h3>
					<p>{app.note}</p>
				</a>
			))
		}
	</div>
</section>

<style>
	.open-app-strip {
		display: grid;
		grid-template-columns: repeat(5, minmax(9rem, 1fr));
		gap: 1rem;
		align-items: center;
		overflow-x: auto;
		padding: 2.5rem 1.25rem;
		scroll-snap-type: x proximity;
	}

	.open-app-card {
		display: block;
		min-height: 13rem;
		min-width: 9rem;
		scroll-snap-align: center;
		transform: translateY(var(--rise)) rotate(var(--tilt));
		border: 1px solid var(--line);
		border-radius: 0.5rem;
		background:
			radial-gradient(
				circle at top left,
				color-mix(in srgb, var(--app-accent) 18%, transparent),
				transparent 58%
			),
			var(--paper);
		padding: 1rem;
		box-shadow: 0 0.35rem 0.9rem color-mix(in srgb, var(--page-shadow) 64%, transparent);
		text-decoration: none;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
		will-change: transform;
	}

	.open-app-card:hover,
	.open-app-card:focus-visible {
		transform: translateY(calc(var(--rise) - 0.45rem)) rotate(var(--tilt));
		border-color: color-mix(in srgb, var(--app-accent) 42%, var(--line));
		box-shadow: 0 0.65rem 1.2rem color-mix(in srgb, var(--page-shadow) 72%, transparent);
	}

	.open-app-card:focus-visible {
		outline: 0.15rem solid color-mix(in srgb, var(--app-accent) 72%, var(--accent-strong));
		outline-offset: 0.18rem;
	}

	.open-app-icon {
		display: block;
		width: 3.4rem;
		height: 3.4rem;
		border-radius: 1rem;
		border: 1px solid var(--line);
		background: var(--paper-raised);
		object-fit: cover;
	}

	.open-app-card h3 {
		margin-top: 1.2rem;
		color: var(--ink);
		font-size: clamp(1.02rem, 1.2vw, 1.18rem);
		font-weight: 600;
		line-height: 1.15;
	}

	.open-app-card p {
		margin-top: 0.55rem;
		color: var(--muted);
		font-size: 0.95rem;
		line-height: 1.35;
	}

	@media (max-width: 767px) {
		.open-app-strip {
			grid-template-columns: minmax(0, 1fr);
			gap: 1.65rem;
			overflow: visible;
			padding: 1rem 0.5rem 1.6rem;
			scroll-snap-type: none;
		}

		.open-app-card {
			width: min(68vw, 15.5rem);
			min-width: 0;
			scroll-snap-align: none;
			transform: rotate(var(--tilt));
		}

		.open-app-card:nth-child(odd) {
			justify-self: start;
			margin-left: 0.35rem;
		}

		.open-app-card:nth-child(even) {
			justify-self: end;
			margin-right: 0.35rem;
		}

		.open-app-card:hover,
		.open-app-card:focus-visible {
			transform: translateY(-0.45rem) rotate(var(--tilt));
		}
	}
</style>
