<section
	class="event-interest relative z-10 my-16 lg:-ml-20 lg:w-[calc(100%+10rem)]"
	aria-label="Event interest placeholder"
>
	<div class="mx-auto max-w-3xl rounded-lg border border-(--line) bg-(--paper) p-5 shadow-[0_0.6rem_1.4rem_var(--page-shadow)] sm:p-6">
		<div class="grid gap-5 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
			<button
				type="button"
				class="inline-flex min-h-12 items-center justify-center rounded-lg border border-(--accent-strong) bg-(--accent-strong) px-5 py-2.5 text-base font-semibold text-white transition hover:brightness-105 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--ink)"
			>
				I'd like to go to your event
			</button>

			<label class="flex items-start gap-3 text-[clamp(1rem,1.25vw,1.12rem)] leading-relaxed text-(--ink)">
				<input
					type="checkbox"
					class="mt-1 size-5 rounded border-(--line-strong) accent-(--accent-strong)"
				/>
				<span>
					even if there's no tame impala
					<span class="mt-1 block italic text-(--muted)">(so there's no stress Kev)</span>
				</span>
			</label>
		</div>
	</div>
</section>
