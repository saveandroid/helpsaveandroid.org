---
import grandmaImage from '@/assets/grandma.png';
import geekImage from '@/assets/geek.png';
import devImage from '@/assets/dev.png';

const { class: className = '', size = 'default' } = Astro.props;
const widthStyle = size === 'compact' ? '--phone-width: min(74vw, 19rem);' : undefined;
const scanTitleId = `apk-scan-title-${size}`;
---

<div
	class:list={[
		'phone-shell phone-frame transition-transform duration-500',
		size === 'compact' && 'phone-frame--compact',
		className,
	]}
	style={widthStyle}
	data-phone
	data-mode="chat"
	data-scan-open="false"
	aria-label="Mock Android phone showing a scam warning conversation and safer Android user groups"
>
	<div class="phone-speaker"></div>

	<div class="phone-screen">
		<div class="chat-screen absolute inset-0 overflow-hidden rounded-[inherit]">
			<div class="flex h-full flex-col bg-[#e6efdc]">
				<div class="bg-[#0b6b41] px-5 pb-4 pt-3 text-white">
					<div class="phone-status mb-4 flex items-center justify-between font-medium text-white/70">
						<span>10:32</span>
						<span>LTE 42%</span>
					</div>
					<div class="flex items-center gap-3">
						<div class="phone-avatar grid h-10 w-10 place-items-center rounded-full bg-white/18">?</div>
						<div>
							<p class="phone-contact-name font-semibold leading-tight">Unknown Number</p>
							<p class="phone-contact-meta leading-tight text-white/78">+00 8XX XXX 4921</p>
						</div>
					</div>
				</div>

				<div class="flex flex-1 flex-col gap-3 bg-[#eef2e5] px-4 pb-8 pt-5">
					<div class="max-w-[86%] rounded-2xl rounded-tl-none bg-white px-4 py-3 shadow-sm">
						<p class="phone-message-text leading-snug text-[#243126]">
							Your refund is approved. Install this Android security update to receive payment.
						</p>
						<p class="phone-message-time mt-1 text-right text-[#697568]">10:32</p>
					</div>

					<button
						type="button"
						class="urgent-pulse pointer-events-auto max-w-[91%] rounded-2xl rounded-tl-none border border-[rgba(200,78,85,.24)] bg-white px-3 py-3 text-left shadow-sm transition-transform hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--rose)]"
						data-apk-trigger
						aria-haspopup="dialog"
						aria-expanded="false"
					>
						<div class="flex items-center gap-3">
							<div
								class="phone-apk-label grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-[var(--rose)] font-bold text-white"
							>
								APK
							</div>
							<div class="min-w-0">
								<p class="phone-file-name truncate font-semibold text-[#243126]">Secure Refund Update.apk</p>
								<p class="phone-file-meta text-[#697568]">2.8 MB - Tap To Install</p>
							</div>
						</div>
						<p class="phone-message-time mt-2 text-right text-[#697568]">10:33</p>
					</button>

					<div class="ml-auto max-w-[78%] rounded-2xl rounded-tr-none bg-[#d5f5c4] px-4 py-3 shadow-sm">
						<p class="phone-message-text leading-snug text-[#243126]">Who is this?</p>
						<p class="phone-message-time mt-1 text-right text-[#697568]">10:35</p>
					</div>

					<div class="mt-auto rounded-2xl border border-[#d0dcc7] bg-white/80 px-4 py-3">
						<div class="flex items-center justify-between gap-3">
							<p class="phone-warning-title font-semibold text-[#344136]">Hey, this is a scam!</p>
							<span class="h-2.5 w-2.5 rounded-full bg-(--rose)"></span>
						</div>
						<p class="phone-warning-text mt-1 leading-snug text-[#5f6d61]">
							This fake refund update is trying to bypass safety checks, read your screen, and capture private
							messages.
						</p>
					</div>
				</div>

				<div
					class="apk-scan-layer pointer-events-none absolute inset-0 z-20 grid place-items-center bg-[rgba(21,22,17,.24)] px-4 opacity-0 backdrop-blur-[2px]"
					aria-hidden="true"
					data-apk-dialog
				>
					<div
						class="apk-scan-dialog relative w-full max-w-[18rem] translate-y-3 rounded-3xl border border-[rgba(21,22,17,.16)] bg-[#f9fbf5] p-4 text-[#243126] opacity-0 shadow-[0_1.4rem_3rem_rgba(21,22,17,.28)]"
						role="dialog"
						aria-modal="true"
						aria-labelledby={scanTitleId}
					>
						<button
							type="button"
							class="pointer-events-auto absolute right-3 top-3 grid h-8 w-8 shrink-0 place-items-center text-[#536052] transition-colors hover:text-[#17623b] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--android-green-strong)]"
							data-apk-close
							aria-label="Close app scan"
						>
							<svg
								viewBox="0 0 24 24"
								width="18"
								height="18"
								aria-hidden="true"
								fill="none"
								stroke="currentColor"
								stroke-width="2.4"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M18 6 6 18"></path>
								<path d="m6 6 12 12"></path>
							</svg>
						</button>

						<div
							class="scan-orbit mx-auto mb-3"
							aria-hidden="true"
						>
						</div>

						<div class="border-b border-[#d9e2d1] pb-3">
							<div class="text-left">
								<p
									id={scanTitleId}
									class="phone-scan-title font-semibold leading-tight"
								>
									currently scanning this app...
								</p>
								<p class="phone-scan-meta mt-1 text-[#697568]">Secure Refund Update.apk</p>
							</div>
						</div>

						<ul class="phone-scan-list mt-4 grid gap-2.5">
							<li>
								<span class="scan-status scan-status--unknown"></span>
								<span>was not in the open app database</span>
							</li>
							<li>
								<span class="scan-status scan-status--danger"></span>
								<span>tried to obfuscate what it does</span>
							</li>
							<li>
								<span class="scan-status scan-status--danger"></span>
								<span>asked to read notifications and texts</span>
							</li>
							<li>
								<span class="scan-status scan-status--danger"></span>
								<span>tried to watch the screen</span>
							</li>
						</ul>

						<div class="mt-4 rounded-2xl bg-[#f1ddd9] px-3 py-2 text-[#7b2830]">
							<p class="phone-scan-verdict font-semibold">This install has been blocked.</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="people-screen absolute inset-0 overflow-hidden rounded-3xl">
			<div class="relative h-full overflow-hidden bg-[linear-gradient(180deg,#f8fbf2_0%,#dfead3_100%)]">
				<div
					class="absolute inset-x-0 top-0 z-10 border-b border-[rgba(21,22,17,.12)] bg-white/74 px-5 pb-3 pt-10 backdrop-blur"
				>
					<div class="flex items-center justify-between">
						<p class="phone-people-title font-semibold font-serif text-[#273021]">A Calmer Android...</p>
						<span class="h-3 w-3 rounded-full bg-[var(--accent)]"></span>
					</div>
				</div>

				<div class="absolute inset-0 top-20">
					<div
						class="absolute left-[-3.7rem] top-4 h-56 w-56 overflow-hidden rounded-full border-[0.45rem] border-[#ee9aa2] bg-white shadow-[0_1.2rem_2.5rem_rgba(21,22,17,.18)]"
					>
						<img
							src={grandmaImage.src}
							alt="Grandma"
							class="h-full w-full object-cover"
						/>
					</div>

					<div
						class="absolute right-[-2rem] top-52 h-56 w-56 overflow-hidden rounded-full border-[0.45rem] border-[var(--accent)] bg-white shadow-[0_1.2rem_2.5rem_rgba(21,22,17,.18)]"
					>
						<img
							src={geekImage.src}
							alt="Geek"
							class="h-full w-full object-cover"
						/>
					</div>

					<div
						class="absolute bottom-7 left-[-3.3rem] h-56 w-56 overflow-hidden rounded-full border-[0.45rem] border-[var(--blue)] bg-white shadow-[0_1.2rem_2.5rem_rgba(21,22,17,.18)]"
					>
						<img
							src={devImage.src}
							alt="Developer"
							class="h-full w-full object-cover"
						/>
					</div>
				</div>

				<div
					class="absolute bottom-5 left-5 right-5 rounded-full border border-[rgba(21,22,17,.13)] bg-white/82 p-2 shadow-sm backdrop-blur"
				>
					<p class="phone-people-caption leading-snug text-[#4d5748] italic text-center">
						a system that's better for everyone.
					</p>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.phone-frame {
		position: relative;
		width: var(--phone-width, min(76vw, 23.25rem));
		aspect-ratio: 9 / 18.5;
		--phone-status-size: 0.7rem;
		--phone-avatar-size: 1.25rem;
		--phone-contact-size: 1.125rem;
		--phone-contact-meta-size: 0.875rem;
		--phone-message-size: 1.05rem;
		--phone-message-time-size: 0.75rem;
		--phone-apk-size: 0.875rem;
		--phone-file-name-size: 1rem;
		--phone-file-meta-size: 0.875rem;
		--phone-warning-title-size: 0.875rem;
		--phone-warning-text-size: 0.875rem;
		--phone-scan-title-size: 0.92rem;
		--phone-scan-meta-size: 0.72rem;
		--phone-scan-list-size: 0.78rem;
		--phone-scan-verdict-size: 0.78rem;
		--phone-people-title-size: 1.125rem;
		--phone-people-caption-size: 0.875rem;
		border: 0.48rem solid color-mix(in srgb, var(--ink) 88%, var(--paper) 12%);
		border-radius: 2.55rem;
		background: color-mix(in srgb, var(--ink) 88%, var(--paper) 12%);
		box-shadow:
			0 2.2rem 5rem var(--page-shadow),
			inset 0 0 0 1px color-mix(in srgb, var(--paper) 28%, transparent);
	}

	.phone-frame--compact {
		--phone-status-size: 0.62rem;
		--phone-avatar-size: 1.05rem;
		--phone-contact-size: 0.98rem;
		--phone-contact-meta-size: 0.78rem;
		--phone-message-size: 0.78rem;
		--phone-message-time-size: 0.68rem;
		--phone-apk-size: 0.78rem;
		--phone-file-name-size: 0.86rem;
		--phone-file-meta-size: 0.78rem;
		--phone-warning-title-size: 0.78rem;
		--phone-warning-text-size: 0.76rem;
		--phone-scan-title-size: 0.78rem;
		--phone-scan-meta-size: 0.62rem;
		--phone-scan-list-size: 0.65rem;
		--phone-scan-verdict-size: 0.66rem;
		--phone-people-title-size: 0.98rem;
		--phone-people-caption-size: 0.78rem;
	}

	.phone-speaker {
		position: absolute;
		z-index: 2;
		top: 0.72rem;
		left: 50%;
		width: 3.8rem;
		height: 0.28rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--paper) 24%, var(--ink) 76%);
		transform: translateX(-50%);
	}

	.phone-screen {
		position: absolute;
		inset: 0.56rem;
		isolation: isolate;
		overflow: hidden;
		border-radius: 2rem;
		background:
			radial-gradient(
				circle at 20% 9%,
				color-mix(in srgb, var(--android-green) 16%, transparent),
				transparent 28%
			),
			linear-gradient(
				180deg,
				var(--android-surface),
				color-mix(in srgb, var(--paper) 78%, var(--accent-soft) 22%)
			);
		font-family:
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			sans-serif;
		text-rendering: geometricPrecision;
	}

	.phone-screen::after {
		position: absolute;
		right: 38%;
		bottom: 0.55rem;
		left: 38%;
		z-index: 30;
		height: 0.25rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--ink) 38%, transparent);
		content: '';
	}

	.phone-status {
		font-size: var(--phone-status-size);
	}

	.phone-avatar {
		font-size: var(--phone-avatar-size);
	}

	.phone-contact-name {
		font-size: var(--phone-contact-size);
	}

	.phone-contact-meta {
		font-size: var(--phone-contact-meta-size);
	}

	.phone-message-text {
		font-size: var(--phone-message-size);
	}

	.phone-message-time {
		font-size: var(--phone-message-time-size);
	}

	.phone-apk-label {
		font-size: var(--phone-apk-size);
	}

	.phone-file-name {
		font-size: var(--phone-file-name-size);
	}

	.phone-file-meta {
		font-size: var(--phone-file-meta-size);
	}

	.phone-warning-title {
		font-size: var(--phone-warning-title-size);
	}

	.phone-warning-text {
		font-size: var(--phone-warning-text-size);
	}

	.phone-scan-title {
		font-size: var(--phone-scan-title-size);
	}

	.phone-scan-meta {
		font-size: var(--phone-scan-meta-size);
	}

	.phone-scan-list {
		padding: 0;
		margin-left: 0;
		list-style: none;
		font-size: var(--phone-scan-list-size);
		line-height: 1.25;
	}

	.phone-scan-list li {
		display: grid;
		grid-template-columns: 0.65rem minmax(0, 1fr);
		align-items: start;
		gap: 0.55rem;
	}

	.scan-status {
		width: 0.55rem;
		height: 0.55rem;
		margin-top: 0.23rem;
		border-radius: 999px;
	}

	.scan-status--unknown {
		background: var(--amber);
	}

	.scan-status--danger {
		background: var(--rose);
	}

	.phone-scan-verdict {
		font-size: var(--phone-scan-verdict-size);
	}

	.scan-orbit {
		position: relative;
		width: 4.25rem;
		height: 4.25rem;
		border-radius: 999px;
		background:
			radial-gradient(circle, var(--android-green-strong) 0 0.24rem, transparent 0.28rem),
			repeating-radial-gradient(
				circle,
				color-mix(in srgb, var(--android-green-strong) 34%, transparent) 0 1px,
				transparent 1px 0.82rem
			),
			radial-gradient(
				circle,
				color-mix(in srgb, var(--android-green) 14%, transparent) 0 1.75rem,
				transparent 1.8rem
			);
		animation: scan-breathe 2.4s ease-in-out infinite;
	}

	.scan-orbit::before {
		position: absolute;
		inset: 0.42rem;
		border-radius: inherit;
		border: 1px solid color-mix(in srgb, var(--android-green-strong) 42%, transparent);
		content: '';
	}

	.apk-scan-layer,
	.apk-scan-dialog {
		transition:
			opacity 240ms ease,
			transform 240ms ease;
	}

	.phone-shell[data-scan-open='true'] .apk-scan-layer {
		pointer-events: auto;
		opacity: 1;
	}

	.phone-shell[data-scan-open='true'] .apk-scan-dialog {
		transform: translateY(0);
		opacity: 1;
	}

	@keyframes scan-breathe {
		0%,
		100% {
			opacity: 0.74;
			transform: scale(0.98);
		}

		50% {
			opacity: 1;
			transform: scale(1.03);
		}
	}

	.phone-people-title {
		font-size: var(--phone-people-title-size);
	}

	.phone-people-caption {
		font-size: var(--phone-people-caption-size);
	}

	.chat-screen,
	.people-screen {
		clip-path: inset(0 round 2rem);
		will-change: opacity;
	}

	.phone-shell.is-ready .chat-screen,
	.phone-shell.is-ready .people-screen {
		transition: opacity 320ms ease;
	}
</style>
